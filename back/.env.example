DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use sqlite for local development. Change to postgres when using docker-compose or a real DB.
DB_ENGINE=sqlite
POSTGRES_DB=futsi
POSTGRES_USER=futsi
POSTGRES_PASSWORD=futsi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production with Supabase Postgres.
# Use the connection string from Supabase Dashboard > Project Settings > Database.
# Prefer the transaction pooler URL for serverless/managed hosts and keep sslmode=require.
# Example only; never commit a real password.
SUPABASE_DATABASE_URL=postgresql://postgres.uqvjilgskrqehkdpkhvq:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_SSLMODE=require
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
