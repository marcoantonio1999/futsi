DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Futsi usa Supabase/Postgres tambien en local. SQLite queda deshabilitado por default.
# Recomendado: variables separadas para evitar errores si el password contiene caracteres especiales.
DB_ENGINE=postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres.uqvjilgskrqehkdpkhvq
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_HOST=aws-1-us-west-2.pooler.supabase.com
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=true

# Alternativa: connection string de Supabase Dashboard > Project Settings > Database.
# No configures SUPABASE_DATABASE_URL si usas POSTGRES_*.
# SUPABASE_DATABASE_URL=postgresql://postgres.uqvjilgskrqehkdpkhvq:YOUR_URL_ENCODED_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Solo para tests/demo aislada, no para desarrollo normal:
# DB_ENGINE=sqlite
# ALLOW_SQLITE=true

# Pase automatico local: por default borra el video descargado/subido al terminar.
# Activa esto solo para depurar errores y conservar videos fallidos en media/automatic_attendance/errores.
AUTO_ATTENDANCE_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider
AUTO_ATTENDANCE_EVIDENCE_BUCKET=automatic-attendance-evidence
AUTO_ATTENDANCE_KEEP_FAILED_VIDEO=false
AUTO_ATTENDANCE_PROBE_WINDOW_SECONDS=4
AUTO_ATTENDANCE_DENSE_FRAME_STRIDE=8
AUTO_ATTENDANCE_MIN_WINDOW_COVERAGE_RATIO=0.80
AUTO_ATTENDANCE_VIDEO_CLUSTER_SIMILARITY=0.52
AUTO_ATTENDANCE_CLUSTER_TOP_FACES=3
AUTO_ATTENDANCE_MAX_FACE_GROUPS=80
AUTO_ATTENDANCE_MIN_DET_SCORE=0.45
AUTO_ATTENDANCE_MIN_FACE_SIZE=24
AUTO_ATTENDANCE_MIN_BLUR=5
UNKNOWN_ATTENDANCE_FACE_BUCKET=unknown-attendance-faces
UNKNOWN_ATTENDANCE_MIN_DET_SCORE=0.80
UNKNOWN_ATTENDANCE_MIN_FACE_SIZE=120
UNKNOWN_ATTENDANCE_MIN_BLUR=80
UNKNOWN_ATTENDANCE_MAX_CENTER_WHITE_RATIO=0.085
UNKNOWN_ATTENDANCE_MIN_MEAN_LUMA=70
UNKNOWN_ATTENDANCE_MIN_MEDIAN_LUMA=60
UNKNOWN_ATTENDANCE_MAX_DARK_RATIO=0.60
UNKNOWN_ATTENDANCE_KNOWN_THRESHOLD=0.35
UNKNOWN_ATTENDANCE_DUPLICATE_THRESHOLD=0.55
UNKNOWN_ATTENDANCE_DOWNLOAD_WORKERS=8
UNKNOWN_ATTENDANCE_KEEP_DOWNLOADED=false
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
